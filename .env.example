# Copy to .env.local and fill in real values.
# Never commit .env.local to git.

# Slack incoming webhook URL (from api.slack.com/apps → your app → Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Arbitrary secret — generate with: openssl rand -hex 32
# Must match VITE_LOGGING_API_KEY in the mega-demo app's .env
API_KEY=
